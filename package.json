{
  "name": "sendwave",
  "version": "1.0.0",
  "description": "Envío masivo de mensajes por WhatsApp",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build:frontend": "cd frontend && npm run build",
    "dist": "npm run build:frontend && electron-builder --win",
    "pack": "npm run build:frontend && electron-builder --dir",
    "install:all": "cd backend && npm install && cd ../frontend && npm install"
  },
  "build": {
    "appId": "com.sendwave.app",
    "productName": "SendWave",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!.auth_state",
          "!.auth_state/**"
        ]
      },
      {
        "from": "frontend/out",
        "to": "frontend/out"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SendWave"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BrSilvinha/sendwave.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/BrSilvinha/sendwave/issues"
  },
  "homepage": "https://github.com/BrSilvinha/sendwave#readme",
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
